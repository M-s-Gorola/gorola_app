# ------------------------------------------------------------------------------
# Frontend (Vite) — copy to `.env`; values are baked in at build time for the browser
# ------------------------------------------------------------------------------
# API origin (no trailing slash): must match where the GoRola API is reachable from the browser (CORS + calls).
VITE_API_BASE_URL=http://localhost:3001

# ------------------------------------------------------------------------------
# Map Provider — controls which map SDK is used inside <OrderRouteMap />
#   (OrderConfirmationPage, BookingConfirmationPage, RiderOrdersPage all use it)
# ------------------------------------------------------------------------------
#
# VITE_MAP_PROVIDER
#   Accepted values : 'leaflet'  (default) | 'ola'
#   If NOT set      : falls back to 'leaflet' — OpenStreetMap tiles, no API key needed,
#                     fully private and offline-capable. Safe default for all environments.
#   If set to 'ola' : switches all maps to the Ola Maps SDK. VITE_OLA_MAPS_API_KEY
#                     must also be set or every map panel will show an error banner instead
#                     of a map (no crash, but maps are broken).
#   If set to anything else (e.g. 'google') : the adapter factory throws a TypeError at
#                     runtime and the map panel shows the same error banner.
#
VITE_MAP_PROVIDER=leaflet

#
# VITE_OLA_MAPS_API_KEY
#   Required when   : VITE_MAP_PROVIDER=ola
#   If NOT set      : OlaMapAdapter.init() throws "VITE_OLA_MAPS_API_KEY is not configured".
#                     OrderRouteMap catches this and renders an inline error:
#                     "Map could not be loaded — API key missing" (non-fatal, page still works).
#   If set but wrong: Ola Maps SDK loads but returns a 401 / tiles fail to render.
#   How to get one  : https://maps.olakarto.com/ → Developer Console → Create API Key
#   Local dev       : leave empty if you are using the default 'leaflet' provider.
#
VITE_OLA_MAPS_API_KEY=
