# ------------------------------------------------------------------------------
# Core — set these first for local API (`pnpm --filter @gorola/api dev` or similar)
# ------------------------------------------------------------------------------
DATABASE_URL=
# Same engine as DATABASE_URL but for automated tests only (CI / separate test DB if you use one).
DATABASE_URL_TEST=
REDIS_URL=

# ------------------------------------------------------------------------------
# JWT (RS256 buyer access tokens)
#
# Leave JWT_PRIVATE_KEY and JWT_PUBLIC_KEY empty for local development: the API
# generates ephemeral RSA keys when env vars are missing or not valid PEM.
#
# Production: paste full PEM strings (BEGIN … END blocks). Dummy/placeholder
# strings are ignored in non-production and ephemeral keys are used instead.
# ------------------------------------------------------------------------------
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ------------------------------------------------------------------------------
# Optional integrations — only when you enable these features in code
# ------------------------------------------------------------------------------
FAST2SMS_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ------------------------------------------------------------------------------
# Server / app
# ------------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=
APP_ENV=development
NODE_ENV=development
LOG_LEVEL=info
PORT=3001
FRONTEND_URL=http://localhost:5173

# ------------------------------------------------------------------------------
# Prisma — direct connection (e.g. migrations); leave empty unless your setup uses it
# ------------------------------------------------------------------------------
DIRECT_URL=

# ------------------------------------------------------------------------------
# OpenTelemetry — leave exporter empty to rely on console in dev; OTEL_ENABLED=false disables the SDK
# ------------------------------------------------------------------------------
OTEL_EXPORTER_ENDPOINT=http://localhost:4318/v1/traces
OTEL_ENABLED=true
OTEL_SERVICE_NAME=gorola-api

# ------------------------------------------------------------------------------
# Test harness only — used when NODE_ENV=test (deterministic OTP in buyer auth integration tests).
# Do not set GOROLA_TEST_OTP in your normal developer .env.
# ------------------------------------------------------------------------------
# GOROLA_TEST_OTP=111222
